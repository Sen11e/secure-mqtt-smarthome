"""
加密工具模块 - 提供签名、验签、时间戳检查功能
用于抵御重放攻击
"""
import hmac
import hashlib
import time
from typing import Any, Dict, Optional


def generate_signature(secret: str, seq_num: int, timestamp: int, payload: Dict[str, Any]) -> str:
    """
    生成HMAC-SHA256签名
    """
    message = f"{seq_num}|{timestamp}|{str(payload)}"
    signature = hmac.new(
        secret.encode('utf-8'),
        message.encode('utf-8'),
        hashlib.sha256
    ).hexdigest()
    return signature


def verify_signature(
    secret: str,
    seq_num: int,
    timestamp: int,
    payload: Dict[str, Any],
    signature: str
) -> bool:
    """
    验证签名是否正确
    """
    expected = generate_signature(secret, seq_num, timestamp, payload)
    return hmac.compare_digest(expected, signature)


def check_timestamp(timestamp: int, window: int = 300) -> bool:
    """
    检查时间戳是否在允许的窗口内
    默认窗口为5分钟(300秒)
    """
    current_time = int(time.time())
    return abs(current_time - timestamp) <= window


def check_seq_num(seq_num: int, last_seq: Optional[int]) -> bool:
    """
    检查序列号是否新颖(大于已处理的最大序列号)
    """
    if last_seq is None:
        return True
    return seq_num > last_seq


def create_signed_message(secret: str, seq_num: int, payload: Dict[str, Any]) -> Dict[str, Any]:
    """
    创建带签名和时间戳的消息
    """
    timestamp = int(time.time())
    signature = generate_signature(secret, seq_num, timestamp, payload)
    return {
        "seq_num": seq_num,
        "timestamp": timestamp,
        "payload": payload,
        "signature": signature
    }